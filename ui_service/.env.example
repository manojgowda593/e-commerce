# UI Service Environment Variables
# For EKS: Create ConfigMap from this file

# Django Settings
DEBUG=False
SECRET_KEY=change-this-to-a-secure-random-key-in-production
ALLOWED_HOSTS=*

# API Gateway URL
API_GATEWAY_URL=http://api-gateway:8000

# Server Settings
PORT=8080

# Service Name
SERVICE_NAME=ui-service
